<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLister"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".DockerListerFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/dis4"
        tools:context=".DockerListerFragment">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/dis3"
            android:elevation="0dp"
            android:minHeight="72dp"
            app:navigationIconTint="@color/blue_main"
            app:layout_constraintTop_toTopOf="parent">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/docker_containers_title"
                    android:textColor="@color/disText2"
                    android:textSize="25sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvContainerListerEndpointName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:includeFontPadding="false"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    tools:text="Endpoint Name"
                    android:textColor="@color/disText2"
                    android:textSize="14sp"
                    android:textStyle="italic" />
            </LinearLayout>

        </com.google.android.material.appbar.MaterialToolbar>

        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swiperLayout"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/toolbarMenu">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">


                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardContainerSummary"
                    style="@style/kontainerSummaryCardStyle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="4dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:baselineAligned="false"
                        android:orientation="horizontal"
                        android:paddingHorizontal="8dp"
                        android:paddingVertical="18dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvSummaryRunning"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                                android:textColor="@color/status_running"
                                android:textStyle="bold"
                                tools:text="34" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/running"
                                android:textAllCaps="true"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="@color/disText1" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvSummaryUnhealthy"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                                android:textColor="@color/status_unhealthy"
                                android:textStyle="bold"
                                tools:text="0" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/unhealthy"
                                android:textAllCaps="true"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="@color/disText1" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvSummaryExited"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                                android:textColor="@color/status_exited"
                                android:textStyle="bold"
                                tools:text="20" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/filter_exited"
                                android:textAllCaps="true"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="@color/disText1" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:orientation="vertical">

                            <com.google.android.material.textview.MaterialTextView
                                android:id="@+id/tvSummaryTotal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textAppearance="@style/TextAppearance.Material3.HeadlineMedium"
                                android:textColor="@color/blue_main"
                                android:textStyle="bold"
                                tools:text="71" />

                            <com.google.android.material.textview.MaterialTextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/total"
                                android:textAllCaps="true"
                                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                                android:textColor="@color/disText1" />
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:id="@+id/llFilterSort"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingHorizontal="8dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <com.google.android.material.textview.MaterialTextView
                            android:id="@+id/tvContainerCount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textAppearance="@style/TextAppearance.Material3.TitleMedium"
                            android:textColor="@color/disText2"
                            tools:text="71 containers" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnSort"
                            style="@style/kontainerSortButtonStyle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:contentDescription="@string/sort_containers"
                            android:text="@string/sort_by_name"
                            android:textAllCaps="false"
                            app:icon="@drawable/ic_sort"
                            app:iconGravity="textStart" />
                    </LinearLayout>

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:scrollbars="none">

                        <com.google.android.material.chip.ChipGroup
                            android:id="@+id/cgStateFilters"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:chipSpacingHorizontal="6dp"
                            app:singleLine="true"
                            app:singleSelection="false">

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipFilterRunning"
                                style="@style/kontainerFilterChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checkable="true"
                                android:text="@string/filter_running" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipFilterHealthy"
                                style="@style/kontainerFilterChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checkable="true"
                                android:text="@string/filter_healthy" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipFilterExited"
                                style="@style/kontainerFilterChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checkable="true"
                                android:text="@string/filter_exited" />

                            <com.google.android.material.chip.Chip
                                android:id="@+id/chipFilterCreated"
                                style="@style/kontainerFilterChipStyle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:checkable="true"
                                android:text="@string/filter_created" />
                        </com.google.android.material.chip.ChipGroup>
                    </HorizontalScrollView>
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/llSearchTerm"
                    style="@style/Widget.Material3.TextInputLayout.FilledBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:layout_marginTop="4dp"
                    android:hint="@string/search_hint"
                    app:boxBackgroundColor="@color/dis3"
                    app:boxCornerRadiusBottomEnd="28dp"
                    app:boxCornerRadiusBottomStart="28dp"
                    app:boxCornerRadiusTopEnd="28dp"
                    app:boxCornerRadiusTopStart="28dp"
                    app:endIconMode="clear_text"
                    app:startIconDrawable="@drawable/ic_search"
                    app:startIconTint="@color/blue_main">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etSearchTerm"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:importantForAutofill="no"
                        android:inputType="textNoSuggestions"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_view"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginStart="4dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="4dp"
                    android:layout_marginBottom="4dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/toolbarMenu"
                    tools:listitem="@layout/docker_card_item" />
            </LinearLayout>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/nav_view"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:layout_marginEnd="12dp"
        android:background="@drawable/bg_navigation_drawer"
        android:clickable="true"
        android:elevation="12dp"
        android:orientation="vertical">

        <include
            android:id="@+id/listerHeder"
            layout="@layout/drawer_lister_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/listerHeder"
            app:layout_constraintVertical_bias="0.005">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/kontainerDrawerButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="8dp"
                android:backgroundTint="@color/dis3"
                android:drawableStart="@drawable/ic_logout_icon"
                android:drawablePadding="9dp"
                android:gravity="start|center_vertical"
                android:text="@string/logout"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:drawableTint="@color/disText2" />

            <View
                android:layout_width="250dp"
                android:layout_height="1dp"
                android:layout_gravity="center"
                android:layout_marginTop="5dp"
                android:background="@color/blue_main" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnManageUsers"
                style="@style/kontainerDrawerButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="3dp"
                android:backgroundTint="@color/dis3"
                android:drawableStart="@drawable/ic_users_group"
                android:drawablePadding="9dp"
                android:lineHeight="15dp"
                android:text="@string/manage_users"
                android:textAlignment="textStart"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:drawableTint="@color/disText2" />

            <View
                android:layout_width="250dp"
                android:layout_height="1dp"
                android:layout_gravity="center"
                android:layout_marginTop="5dp"
                android:background="@color/blue_main" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnEndpoints"
                style="@style/kontainerDrawerButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="3dp"
                android:backgroundTint="@color/dis3"
                android:drawableStart="@drawable/ic_endpoints"
                android:drawablePadding="9dp"
                android:lineHeight="15dp"
                android:text="@string/endpoints"
                android:textAlignment="textStart"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:drawableTint="@color/disText2" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDockerEndpoints"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:visibility="gone"
                tools:listitem="@layout/docker_endpoints_card_item">

            </androidx.recyclerview.widget.RecyclerView>

            <View
                android:layout_width="250dp"
                android:layout_height="1dp"
                android:layout_gravity="center"
                android:layout_marginTop="5dp"
                android:background="@color/blue_main" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAbout"
                style="@style/kontainerDrawerButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="3dp"
                android:backgroundTint="@color/dis3"
                android:drawableStart="@drawable/ic_info"
                android:drawablePadding="9dp"
                android:lineHeight="15dp"
                android:text="@string/about"
                android:textAlignment="textStart"
                android:textAllCaps="false"
                android:textSize="15sp"
                app:drawableTint="@color/disText2" />

            <TextView
                android:id="@+id/tvAboutInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:justificationMode="inter_word"
                android:linksClickable="true"
                android:paddingStart="19dp"
                android:paddingEnd="30dp"
                android:textColor="@color/disText2"
                android:textSize="12sp"
                android:visibility="invisible" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHiddenFeatures"
                style="@style/kontainerDrawerButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="50dp"
                android:layout_marginStart="19dp"
                android:layout_marginTop="10dp"
                android:backgroundTint="@color/disRedDisabled"
                android:drawableStart="@drawable/ic_egg"
                android:drawablePadding="9dp"
                android:lineHeight="15dp"
                android:text="@string/hidden_functionalities"
                android:textAlignment="textStart"
                android:textAllCaps="false"
                android:textSize="15sp"
                android:visibility="invisible" />

        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>


</androidx.drawerlayout.widget.DrawerLayout>
