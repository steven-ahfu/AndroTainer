<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".DockerContainerDetailsFragment">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/tbContainerDetails"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/blue_main"
        android:elevation="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvContainerDetailsTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                tools:text="Docker Container"
                android:textColor="@color/dis4"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvContainerDetailsEndpointName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                tools:text="Endpoint Name"
                android:textColor="@color/dis4"
                android:textSize="14sp"
                android:paddingStart="5dp"
                android:paddingEnd="5dp"
                android:textStyle="italic" />
        </LinearLayout>


    </androidx.appcompat.widget.Toolbar>


    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="55dp"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="25dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tbContainerDetails">

            <com.google.android.material.button.MaterialButtonGroup
                android:id="@+id/bgContainerActions"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/ivContainerLogo">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnActionStartStop"
                    style="@style/Widget.Material3Expressive.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_start"
                    android:textColor="@color/disText2" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnActionRestart"
                    style="@style/Widget.Material3Expressive.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_restart"
                    android:textColor="@color/disText2" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnActionPause"
                    style="@style/Widget.Material3Expressive.Button.TonalButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_pause"
                    android:textColor="@color/disText2" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnActionAlerts"
                    style="@style/Widget.Material3Expressive.Button.OutlinedButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/action_alerts"
                    android:textColor="@color/blue_main" />
            </com.google.android.material.button.MaterialButtonGroup>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardContainerStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/dis3"
                app:cardCornerRadius="16dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/bgContainerActions">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/live_stats_title"
                        android:textColor="@color/blue_main"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <com.google.android.material.loadingindicator.LoadingIndicator
                        android:id="@+id/liStatsLoading"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal" />

                    <TextView
                        android:id="@+id/tvStatsContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:textColor="@color/disText2"
                        android:textSize="14sp"
                        android:visibility="gone"
                        tools:text="CPU: 2.1%\nMemory: 480 MiB / 19852 MiB (2.4%)"
                        tools:visibility="visible" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvContainerDetailsInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:paddingHorizontal="10dp"
                tools:text="Insert text here"
                android:textColor="@color/disText2"
                android:textSize="15sp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/cardContainerStats" />

            <ImageView
                android:id="@+id/ivContainerLogo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:contentDescription="@string/container_logo"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <include
                android:id="@+id/btnContainerDelete"
                layout="@layout/delete_docker_container_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_marginTop="25dp"
                android:layout_marginEnd="15dp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvContainerDetailsInfo" />

            <TextView
                android:id="@+id/tv_btn_remove_container_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="41dp"
                android:maxWidth="220dp"
                tools:text="will get it from strings res, but lets fill it with stuff to see the padding now"
                android:textColor="@color/loginDisabledText"
                android:textSize="12sp"
                android:visibility="gone"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.3"
                app:layout_constraintStart_toEndOf="@+id/btnContainerDelete"
                app:layout_constraintTop_toBottomOf="@+id/tvContainerDetailsInfo" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>


