<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/dis3"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvThresholdTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/blue_main"
        android:textSize="18sp"
        android:textStyle="bold"
        tools:text="Alerts for immich_server" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/threshold_explainer"
        android:textColor="@color/disText1"
        android:textSize="12sp" />

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilCpuThreshold"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:hint="@string/threshold_cpu_hint"
        app:boxStrokeColor="@color/blue_main"
        app:hintTextColor="@color/blue_main"
        app:suffixText="%">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etCpuThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="@color/disText2" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilMemThreshold"
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/threshold_mem_hint"
        app:boxStrokeColor="@color/blue_main"
        app:hintTextColor="@color/blue_main"
        app:suffixText="MiB">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etMemThreshold"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"
            android:textColor="@color/disText2" />
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:hint="@string/threshold_interval_hint"
        app:boxStrokeColor="@color/blue_main"
        app:hintTextColor="@color/blue_main">

        <com.google.android.material.textfield.MaterialAutoCompleteTextView
            android:id="@+id/actvMonitorInterval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="none"
            android:textColor="@color/disText2"
            app:simpleItems="@array/monitor_intervals" />
    </com.google.android.material.textfield.TextInputLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:gravity="end"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnThresholdDelete"
            style="@style/Widget.Material3Expressive.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/threshold_delete"
            android:textColor="@color/disRedDisabled" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnThresholdCancel"
            style="@style/Widget.Material3Expressive.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/threshold_cancel"
            android:textColor="@color/disText1" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnThresholdSave"
            style="@style/Widget.Material3Expressive.Button.TonalButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="@string/threshold_save"
            android:textColor="@color/disText2" />
    </LinearLayout>
</LinearLayout>
