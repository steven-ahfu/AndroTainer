<resources>
    <!-- Keep night mode on the same M3 Expressive token system as the base theme. -->
    <style name="Theme.AndroTainer" parent="Theme.Material3Expressive.DayNight.NoActionBar">
        <item name="android:fontFamily">@font/app_font</item>
        <item name="fontFamily">@font/app_font</item>
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/blue_main</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorPrimaryContainer">@color/chipBlue</item>
        <item name="colorOnPrimaryContainer">@color/blue_main</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSecondaryContainer">@color/dis5</item>
        <item name="colorOnSecondaryContainer">@color/disText2</item>
        <item name="android:colorBackground">@color/dis2</item>
        <item name="colorSurface">@color/dis4</item>
        <item name="colorOnSurface">@color/disText2</item>
        <item name="colorSurfaceVariant">@color/dis5</item>
        <item name="colorOnSurfaceVariant">@color/disText1</item>
        <item name="colorSurfaceContainer">@color/dis3</item>
        <item name="colorSurfaceContainerHigh">@color/dis4</item>
        <item name="colorSurfaceContainerHighest">@color/dis5</item>
        <item name="colorOutline">@color/dis7</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/dis4</item>
        <item name="android:textColorPrimary">@color/disText2</item>
        <item name="android:windowBackground">@color/dis2</item>
    </style>


    <style name="customChipStyle" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="android:textColor">@color/chip_text_colors</item>
    </style>

    <style name="actionChipStyle" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_action_background</item>
        <item name="android:textColor">@color/chip_action_text_colors</item>
    </style>

    <style name="kontainerFilterChipStyle" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/chip_background</item>
        <item name="android:textColor">@color/chip_text_colors</item>
        <item name="checkedIconTint">@color/blue_main</item>
    </style>

    <style name="kontainerSummaryCardStyle" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/dis3</item>
        <item name="cardCornerRadius">28dp</item>
        <item name="strokeColor">@color/dis7</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="kontainerSortButtonStyle" parent="Widget.Material3Expressive.Button.TonalButton">
        <item name="android:textColor">@color/disText2</item>
        <item name="backgroundTint">@color/dis5</item>
        <item name="iconTint">@color/blue_main</item>
    </style>

    <style name="kontainerDrawerButtonStyle" parent="Widget.Material3Expressive.Button.TextButton">
        <item name="android:gravity">center_vertical|start</item>
        <item name="android:textColor">@color/disText2</item>
        <item name="backgroundTint">@android:color/transparent</item>
        <item name="iconTint">@color/blue_main</item>
    </style>

    <style name="ThemeOverlay.AndroTainer.PopupMenu" parent="ThemeOverlay.Material3">
        <item name="colorSurface">@color/dis3</item>
        <item name="colorSurfaceContainer">@color/dis3</item>
        <item name="colorOnSurface">@color/disText2</item>
        <item name="android:textColorPrimary">@color/disText2</item>
        <item name="android:itemBackground">@android:color/transparent</item>
        <item name="android:popupMenuStyle">@style/Widget.AndroTainer.PopupMenu</item>
    </style>

    <style name="Widget.AndroTainer.PopupMenu" parent="Widget.Material3.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_popup_menu</item>
        <item name="android:popupElevation">8dp</item>
    </style>

</resources>
